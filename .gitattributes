# Normalize line endings so a Windows dev + Linux CI never produce spurious
# whole-file EOL diffs (this repo had recurring churn on build.gradle.kts).
# Text files are stored with LF in the repository; git auto-detects text.
* text=auto

# Force LF for source and config so they stay consistent across platforms.
*.dart   text eol=lf
*.kt     text eol=lf
*.kts    text eol=lf
*.gradle text eol=lf
*.java   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.xml    text eol=lf
*.sh     text eol=lf
*.md     text eol=lf

# Binary assets — never touched by EOL normalization.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  binary
*.ttf  binary
*.otf  binary
*.woff  binary
*.woff2 binary
*.jar  binary
*.keystore binary
*.so   binary
*.a    binary
